# Server
PORT=3000
# Nur für docker compose auf der NAS (network_mode: host)
HOST_PORT=4289
NODE_ENV=development

# Zeitzone (z. B. Europe/Berlin – selbst setzen)
TZ=UTC

# Standort (Dezimalgrad) – selbst setzen, keine Defaults im Repository
DEFAULT_LAT=
DEFAULT_LON=

# Sonnenwinkel-Schwellwert für Westfassade (Grad)
WEST_ANGLE_THRESHOLD=15

# SQLite-Datenbank für Benutzereinstellungen
DATABASE_PATH=./data/weathergod.db

# Regenradar: RainViewer für Beobachtung; optional LibreWXR nur für Prognose-Frames (+60 min)
# Leer lassen oder RADAR_NOWCAST_URL= setzen, um Prognose zu deaktivieren
RADAR_NOWCAST_URL=https://api.librewxr.net/public/weather-maps.json

# ntfy – Push-Benachrichtigung
# Topic eindeutig wählen: https://ntfy.sh oder Self-Hosted
NTFY_AUTO_ENABLED=false
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=weathergod-mein-eindeutiger-name
# Optional: Token für geschützte Topics
NTFY_TOKEN=
